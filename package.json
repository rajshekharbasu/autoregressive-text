{
  "name": "autoregressive-text",
  "version": "0.1.0",
  "description": "A self-contained React animation that generates text token-by-token like an autoregressive language model — candidate sampling, attention brackets, and a subtle reveal. Zero-config, themeable via CSS variables.",
  "keywords": [
    "react",
    "animation",
    "text-animation",
    "framer-motion",
    "autoregressive",
    "llm",
    "typewriter",
    "attention"
  ],
  "license": "MIT",
  "author": "Rajshekhar Basu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajshekharbasu/autoregressive-text.git"
  },
  "homepage": "https://github.com/rajshekharbasu/autoregressive-text#readme",
  "bugs": {
    "url": "https://github.com/rajshekharbasu/autoregressive-text/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/add-use-client.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "framer-motion": ">=11",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "gradient-shimmer": "^0.1.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "framer-motion": "^12.42.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
